ENV=development
LOG_LEVEL=INFO

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aurora

SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/aurora

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

AUTH_JWT_SECRET=aurora-dev-secret
AUTH_PASSWORD_SALT=aurora-password-salt
DEFAULT_LOGIN_PASSWORD=123456

OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_SCHEME=https

SANDBOX_MODE=docker
SANDBOX_IMAGE=aurora-sandbox
SANDBOX_NAME_PREFIX=aurora-sandbox
SANDBOX_NETWORK=aurora-network
SANDBOX_ADDRESS=127.0.0.1
SANDBOX_BINDING_TTL_HOURS=72

NGINX_PORT=8088
